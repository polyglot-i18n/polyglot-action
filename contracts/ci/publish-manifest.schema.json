{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.getpolyglot.ai/ci/publish-manifest-v1.json",
  "title": "Polyglot catalog publication manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "project_id", "repository_id", "base_sha", "config_path", "config_hash", "catalog_snapshot_hash", "cli_version", "allowed_paths", "documents", "verification", "limits"],
  "properties": {
    "schema_version": {"const": 1}, "run_id": {"type": "string", "minLength": 1},
    "project_id": {"type": "string", "minLength": 1}, "repository_id": {"type": "integer", "minimum": 1},
    "base_sha": {"$ref": "#/$defs/sha"}, "config_path": {"$ref": "#/$defs/path"},
    "config_hash": {"$ref": "#/$defs/hash"}, "catalog_snapshot_hash": {"$ref": "#/$defs/hash"},
    "cli_version": {"type": "string", "minLength": 1},
    "allowed_paths": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/path"}},
    "documents": {"type": "array", "minItems": 1, "maxItems": 1000, "items": {"$ref": "#/$defs/document"}},
    "verification": {"$ref": "#/$defs/verification"}, "limits": {"$ref": "#/$defs/limits"}
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "path": {"type": "string", "minLength": 1, "not": {"pattern": "(^/|(^|/)\\.\\.(/|$)|^[A-Za-z]:[\\\\/])"}},
    "language": {"type": "string", "pattern": "^[A-Za-z]{2,3}([_-][A-Za-z0-9]{2,8})*$"},
    "writer_options": {
      "type": "object", "additionalProperties": false,
      "required": ["key_style", "nested", "sort_keys"],
      "properties": {"key_style": {"enum": ["nested", "flat", "semantic", "native"]}, "nested": {"type": "boolean"}, "sort_keys": {"type": "boolean"}, "namespace": {"type": ["string", "null"]}}
    },
    "update": {
      "type": "object", "additionalProperties": false,
      "required": ["key", "source_key", "value", "translation_id", "translation_version_id", "review_status"],
      "properties": {
        "key": {"type": "string", "minLength": 1}, "source_key": {"type": "string", "minLength": 1},
        "value": {"type": "string"}, "translation_id": {"type": "string", "minLength": 1},
        "translation_version_id": {"type": "string", "minLength": 1},
        "review_status": {"enum": ["approved", "auto_approved"]}
      }
    },
    "document": {
      "type": "object", "additionalProperties": false,
      "required": ["path", "format", "language", "before_hash", "writer_options", "expected_source_keys", "updates"],
      "properties": {
        "path": {"$ref": "#/$defs/path"}, "format": {"enum": ["json", "yaml", "arb", "strings", "xml"]},
        "language": {"$ref": "#/$defs/language"}, "before_hash": {"$ref": "#/$defs/hash"},
        "writer_options": {"$ref": "#/$defs/writer_options"},
        "expected_source_keys": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "updates": {"type": "array", "items": {"$ref": "#/$defs/update"}}
      }
    },
    "verification": {
      "type": "object", "additionalProperties": false,
      "required": ["command_hash", "environment_allowlist"],
      "properties": {"command_hash": {"$ref": "#/$defs/hash"}, "environment_allowlist": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^[A-Z_][A-Z0-9_]*$"}}}
    },
    "limits": {
      "type": "object", "additionalProperties": false,
      "required": ["timeout_seconds", "max_manifest_bytes", "max_file_bytes", "max_changed_files"],
      "properties": {
        "timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 7200},
        "max_manifest_bytes": {"type": "integer", "minimum": 1, "maximum": 5242880},
        "max_file_bytes": {"type": "integer", "minimum": 1, "maximum": 10485760},
        "max_changed_files": {"type": "integer", "minimum": 1, "maximum": 1000}
      }
    }
  }
}
